{
    "manifest_version": 3,
    "name": "Hampter AutoLogin",
    "version": "1.0.5",
    "description": "Automatically logs into Atlantis using your Gmail magic link.",
    "permissions": [
        "identity",
        "storage"
    ],
    "host_permissions": [
        "https://*.atlantis.education/*",
        "https://www.googleapis.com/*",
        "https://api.github.com/*"
    ],
    "oauth2": {
        "client_id": "498560839588-g6h9dq6hmjpub1gbu02ssmigpcl7591b.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/gmail.readonly"
        ]
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.atlantis.education/*"
            ],
            "exclude_matches": [
                "https://*.atlantis.education/*/Covers*"
            ],
            "js": [
                "content_script.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Hampter AutoLogin"
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}
