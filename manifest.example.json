{
    "manifest_version": 3,
    "name": "Hampter Login",
    "version": "1.0",
    "description": "Automatically logs into Atlantis using your Gmail magic link.",
    "permissions": [
        "identity",
        "storage"
    ],
    "host_permissions": [
        "REPLACE_WITH_YOUR_LOGIN_URL",
        "https://www.googleapis.com/*"
    ],
    "oauth2": {
        "client_id": "REPLACE_WITH_YOUR_CLIENT_ID.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/gmail.readonly"
        ]
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "REPLACE_WITH_YOUR_LOGIN_URL"
            ],
            "js": [
                "content_script.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Hampter Login"
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}
